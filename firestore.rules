rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }
    // 'kickoff' se guarda como número (milisegundos desde 1970), no como
    // texto, precisamente para poder compararlo aquí de forma confiable.
    function matchKickoffPassed(matchId) {
      let m = get(/databases/$(database)/documents/profetas/matches/matches/$(matchId)).data;
      return m.kickoff != null && m.kickoff <= request.time.toMillis();
    }

    // Equipos: cualquiera autenticado (aunque sea anónimo) puede leerlos;
    // solo admin puede crear/editar/borrar.
    match /profetas/teams/teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Perfiles: cualquiera autenticado puede leerlos (para el login, la
    // tabla, etc.). Solo se puede crear o editar el perfil propio — el uid
    // de la sesión (que solo se consigue probando el PIN correcto en
    // /api/profile-login) tiene que ser igual al id del documento Y al
    // ownerUid guardado adentro. Admin puede además editar cualquiera
    // (ej. para el bot) y es el único que puede borrar perfiles.
    match /profetas/profiles/profiles/{profileId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() ||
        (isSignedIn() && request.auth.uid == profileId && request.resource.data.ownerUid == profileId);
      allow update: if isAdmin() ||
        (isSignedIn() && request.auth.uid == profileId && request.resource.data.ownerUid == profileId);
      allow delete: if isAdmin();
    }

    // Hashes de PIN: nadie los lee ni los escribe desde el navegador, ni
    // siquiera admin. Solo el Admin SDK (usado en las funciones serverless
    // /api/profile-login, /api/admin-login y /api/migrate-security) puede
    // tocar esta colección, porque el Admin SDK no pasa por estas reglas.
    match /profetas/profilePins/profilePins/{profileId} {
      allow read, write: if false;
    }

    // Contador de intentos fallidos de la contraseña de administrador.
    // Mismo motivo: solo el Admin SDK, nunca el navegador.
    match /profetas/adminAuth/adminAuth/{document} {
      allow read, write: if false;
    }

    // Partidos: cualquiera autenticado los lee; solo admin los crea, edita
    // (cargar/editar resultado) o borra.
    match /profetas/matches/matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      // Predicciones: la propia siempre se puede leer (si no, tu propia
      // predicción "desaparecería" de tu pantalla en cuanto llegara la
      // siguiente actualización en tiempo real). Las de los demás solo se
      // pueden leer si el partido ya cerró (kickoff pasado) o si eres
      // admin — así que ocultarlas hasta el kickoff ya no es solo una
      // regla de la interfaz, también es una regla de acceso a los datos:
      // ni abriendo la consola del navegador se pueden leer de antemano.
      // Solo se puede crear o editar la predicción propia (ownerUid == el
      // propio uid), o admin (necesario para las predicciones del bot
      // "Carlos Antonio Vélez", cuyo ownerUid nunca es un uid real).
      match /predictions/{profileId} {
        allow read: if isAdmin() ||
          (isSignedIn() && request.auth.uid == profileId) ||
          (isSignedIn() && matchKickoffPassed(matchId));
        allow create, update: if isAdmin() ||
          (isSignedIn() && request.auth.uid == profileId && request.auth.uid == request.resource.data.ownerUid);
        allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == profileId);
      }
    }

    // Pre-temporada: sigue siendo un único documento (no se pidió pasarlo a
    // subcolección). Cualquiera autenticado puede editar SOLO su propia
    // entrada dentro de picks{} — el resto del documento (result, y las
    // entradas de otras personas) tiene que quedar exactamente igual, cosa
    // que se verifica comparando qué cambió (diff) contra lo que ya había.
    // Cerrar/calificar la pre-temporada sigue siendo solo de admin.
    match /profetas/preseason {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isSignedIn();
      allow update: if isAdmin() ||
        (isSignedIn() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['picks']) &&
         request.resource.data.picks.diff(resource.data.picks).affectedKeys().hasOnly([request.auth.uid]));
      allow delete: if isAdmin();
    }

    // Tabla real de la liga: cualquiera autenticado la lee, solo admin la edita.
    match /profetas/realStandings {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
